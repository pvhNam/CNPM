# ===== Database (TiDB Cloud / MySQL) =====
MYSQLHOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
MYSQLPORT=4000
MYSQLUSER=your_tidb_user
MYSQLPASSWORD=your_tidb_password
MYSQLDATABASE=o_an_quan_db
# Đặt false nếu chạy MySQL local không có SSL
MYSQL_SSL=true

# ===== Session =====
# Chuỗi bí mật dài, ngẫu nhiên. Gợi ý: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# ===== Runtime =====
# Render tự set PORT, local có thể để trống (mặc định 3000)
PORT=3000
# Đặt 'production' khi deploy để bật secure cookie
NODE_ENV=development
